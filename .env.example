# Environment variables for Railway deployment
# Copy these into Railway project's "Variables" tab

# Discord
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
MAIN_GUILD_ID=your_main_guild_id
DEFAULT_PREFIX=!

# Database
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Dashboard
SESSION_SECRET=change_me_to_a_long_random_string
DEFAULT_LANGUAGE=en

# Public URL for OAuth callback (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
# If you use a custom domain set this manually:
# CALLBACK_URL=https://your-app.up.railway.app/auth/callback

# PORT is provided automatically by Railway, do NOT set it manually.
