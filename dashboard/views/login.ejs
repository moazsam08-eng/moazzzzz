<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Moaz Studio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;background:#05060A;}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .float{animation:float 4s ease-in-out infinite}
    .fade-up{animation:fadeUp .6s ease both}
    .delay-1{animation-delay:.1s}
    .delay-2{animation-delay:.2s}
    .delay-3{animation-delay:.3s}
    .delay-4{animation-delay:.4s}
    .delay-5{animation-delay:.5s}
    .glow-indigo{box-shadow:0 0 40px rgba(88,101,242,.25)}
    .grid-bg{
      background-image:linear-gradient(rgba(88,101,242,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(88,101,242,.04) 1px,transparent 1px);
      background-size:48px 48px;
    }
    input:-webkit-autofill,input:-webkit-autofill:focus{
      -webkit-box-shadow:0 0 0 1000px #1A1C22 inset;
      -webkit-text-fill-color:#fff;
    }
    .discord-btn{
      background:linear-gradient(135deg,#5865F2,#4752C4);
      transition:all .2s ease;
    }
    .discord-btn:hover{
      transform:translateY(-1px);
      box-shadow:0 8px 24px rgba(88,101,242,.4);
    }
    .discord-btn:active{transform:translateY(0)}
    .divider-line{
      flex:1;height:1px;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.07),transparent);
    }
    details summary{list-style:none;cursor:pointer;}
    details summary::-webkit-details-marker{display:none;}
    details[open] .chevron{transform:rotate(180deg);}
    .chevron{transition:transform .2s ease;}
  </style>
</head>
<body class="grid-bg min-h-screen flex items-center justify-center px-4">

  <!-- Ambient glows -->
  <div class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden">
    <div class="absolute top-[-120px] left-[-80px] w-[500px] h-[500px] bg-indigo-600/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[-100px] right-[-60px] w-[400px] h-[400px] bg-purple-600/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative w-full max-w-[420px]">

    <!-- Logo -->
    <div class="flex flex-col items-center mb-8 fade-up">
      <div class="relative float mb-4">
        <div class="w-20 h-20 rounded-2xl overflow-hidden ring-2 ring-indigo-500/40 shadow-xl">
          <img src="/images/logo.png" alt="Moaz Studio" class="w-full h-full object-cover">
        </div>
        <span class="absolute -bottom-1 -right-1 w-5 h-5 bg-emerald-500 rounded-full ring-2 ring-[#05060A]"></span>
      </div>
      <h1 class="text-2xl font-extrabold text-white tracking-tight">Moaz <span class="text-indigo-400">Studio</span></h1>
      <p class="text-xs text-gray-500 mt-1 font-medium">Dashboard Access Control</p>
    </div>

    <!-- Card -->
    <div class="relative rounded-2xl border border-white/[0.07] bg-[#0F1014]/90 backdrop-blur-xl p-8 glow-indigo fade-up delay-1">

      <div class="mb-6">
        <h2 class="text-lg font-bold text-white">Sign in</h2>
        <p class="text-xs text-gray-500 mt-0.5">Access your server dashboard</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-5 flex items-center gap-2 px-3 py-2.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm fade-up">
        <i class="fas fa-circle-exclamation text-xs flex-shrink-0"></i>
        <span><%= error %></span>
      </div>
      <% } %>

      <!-- ── Discord OAuth Button ── -->
      <div class="fade-up delay-2">
        <a href="/auth/discord" id="discordBtn"
           class="discord-btn w-full flex items-center justify-center gap-3 text-white font-bold rounded-xl py-3.5 text-sm shadow-lg">
          <i class="fab fa-discord text-lg"></i>
          Continue with Discord
        </a>
        <p class="text-center text-[11px] text-gray-600 mt-2">
          Automatically shows servers you manage
        </p>
      </div>

      <!-- ── Divider ── -->
      <div class="flex items-center gap-3 my-5 fade-up delay-3">
        <div class="divider-line"></div>
        <span class="text-[11px] text-gray-600 font-medium uppercase tracking-widest">or</span>
        <div class="divider-line"></div>
      </div>

      <!-- ── Manual login (collapsible) ── -->
      <details class="fade-up delay-4">
        <summary class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-white/[0.03] transition-colors">
          <span class="text-xs font-semibold text-gray-500">Manual Login <span class="text-gray-600">(Owner only)</span></span>
          <i class="fas fa-chevron-down text-[10px] text-gray-600 chevron"></i>
        </summary>

        <form method="POST" action="/login" class="space-y-4 mt-4" id="loginForm">
          <!-- Discord ID -->
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-1.5 uppercase tracking-wider">Discord User ID</label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
                <i class="fab fa-discord"></i>
              </span>
              <input type="text" name="userId" id="userId" autocomplete="off" spellcheck="false"
                placeholder="e.g. 148527684971..."
                class="w-full bg-[#1A1C22] border border-white/[0.08] focus:border-indigo-500/60 focus:ring-1 focus:ring-indigo-500/30 rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder-gray-600 outline-none transition-all"
                required>
            </div>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-1.5 uppercase tracking-wider">Password</label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
                <i class="fas fa-lock"></i>
              </span>
              <input type="password" name="password" id="password"
                placeholder="••••••••"
                class="w-full bg-[#1A1C22] border border-white/[0.08] focus:border-indigo-500/60 focus:ring-1 focus:ring-indigo-500/30 rounded-xl pl-10 pr-11 py-3 text-sm text-white placeholder-gray-600 outline-none transition-all"
                required>
              <button type="button" id="togglePwd" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 transition-colors text-sm">
                <i class="fas fa-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>

          <button type="submit" id="submitBtn"
            class="w-full flex items-center justify-center gap-2 bg-white/[0.06] hover:bg-white/[0.09] border border-white/[0.08] active:scale-[.98] text-white font-bold rounded-xl py-3 text-sm transition-all">
            <i class="fas fa-arrow-right-to-bracket"></i>
            Sign In
          </button>
        </form>
      </details>

    </div>

    <!-- Footer -->
    <p class="text-center text-[11px] text-gray-600 mt-6 fade-up delay-5">
      Powered by <span class="text-indigo-400 font-semibold">Moaz Studio</span> &mdash; Discord Bot Dashboard
    </p>
  </div>

  <script>
    document.getElementById('togglePwd')?.addEventListener('click', function(){
      const inp = document.getElementById('password');
      const ic  = document.getElementById('eyeIcon');
      if(inp.type === 'password'){ inp.type='text'; ic.className='fas fa-eye-slash'; }
      else { inp.type='password'; ic.className='fas fa-eye'; }
    });
    document.getElementById('loginForm')?.addEventListener('submit', function(){
      const btn = document.getElementById('submitBtn');
      btn.innerHTML = '<i class="fas fa-spinner animate-spin"></i> Signing in...';
      btn.disabled = true;
    });
    document.getElementById('discordBtn')?.addEventListener('click', function(){
      this.innerHTML = '<i class="fas fa-spinner animate-spin text-lg"></i> Connecting...';
    });
  </script>
</body>
</html>
