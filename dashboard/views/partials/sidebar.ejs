<div class="sidebar animate-mobile fixed inset-y-0 left-0 w-64 bg-[#0F1014] border-r border-white/5 z-60 flex flex-col">
    <div class="sidebar-header px-5 py-5 border-b border-white/5">
        <div class="flex items-center gap-3 group">
            <div class="relative">
                <img src="/images/logo.png" alt="Moaz Studio" class="logo w-11 h-11 rounded-xl shadow-lg ring-2 ring-indigo-500/30 transform group-hover:scale-105 transition-all duration-300 object-cover">
                <span class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-emerald-500 rounded-full ring-2 ring-[#0F1014]"></span>
            </div>
            <div>
                <h1 class="text-base font-bold text-white tracking-tight">
                    Moaz <span class="text-indigo-400">Studio</span>
                </h1>
                <p class="text-[11px] text-gray-500 font-medium">
                    Discord Bot Dashboard
                </p>
            </div>
        </div>
    </div>

    <nav class="sidebar-content flex-1 px-3 py-4 overflow-y-auto custom-scrollbar">
        <!-- MAIN -->
        <div class="mb-5">
            <h2 class="px-3 text-[10px] font-bold text-gray-500 uppercase tracking-[0.15em] mb-2">
                <%= currentLang === 'ar' ? 'الرئيسية' : 'Main' %>
            </h2>
            <div class="space-y-0.5">
                <% const mainLinks = [
                    { path: '/', icon: 'fa-house', en: 'Dashboard', ar: 'لوحة التحكم' },
                    { path: '/settings', icon: 'fa-gear', en: 'Settings', ar: 'الإعدادات' },
                    { path: '/docs', icon: 'fa-book-open', en: 'Documentation', ar: 'التوثيق' }
                ] %>
                <% mainLinks.forEach(link => { %>
                    <a href="<%= link.path %>" class="nav-item <%= path === link.path ? 'active' : '' %>">
                        <i class="fas <%= link.icon %> w-5 text-center text-[15px]"></i>
                        <span class="font-medium text-sm"><%= currentLang === 'ar' ? link.ar : link.en %></span>
                    </a>
                <% }) %>
            </div>
        </div>

        <!-- COMMANDS -->
        <div class="mb-5">
            <h2 class="px-3 text-[10px] font-bold text-gray-500 uppercase tracking-[0.15em] mb-2">
                <%= currentLang === 'ar' ? 'الأوامر' : 'Commands' %>
            </h2>
            <div class="space-y-0.5">
                <a href="/commands/general" class="nav-item <%= path.startsWith('/commands/general') ? 'active' : '' %>">
                    <i class="fas fa-terminal w-5 text-center text-[15px]"></i>
                    <span class="font-medium text-sm"><%= currentLang === 'ar' ? 'الأوامر العامة' : 'General' %></span>
                </a>
                <a href="/commands/moderation" class="nav-item <%= path.startsWith('/commands/moderation') ? 'active' : '' %>">
                    <i class="fas fa-shield-halved w-5 text-center text-[15px]"></i>
                    <span class="font-medium text-sm"><%= currentLang === 'ar' ? 'أوامر الإشراف' : 'Moderation' %></span>
                </a>
            </div>
        </div>

        <!-- MODULES -->
        <div class="mb-5">
            <h2 class="px-3 text-[10px] font-bold text-gray-500 uppercase tracking-[0.15em] mb-2">
                <%= currentLang === 'ar' ? 'الإعدادات' : 'Modules' %>
            </h2>
            <div class="space-y-0.5">
                <% const configLinks = [
                    { path: '/logs', icon: 'fa-clock-rotate-left', en: 'Logs', ar: 'السجلات' },
                    { path: '/tickets', icon: 'fa-ticket', en: 'Tickets', ar: 'التذاكر' },
                    { path: '/leveling', icon: 'fa-chart-line', en: 'Leveling', ar: 'المستويات' },
                    { path: '/rules', icon: 'fa-gavel', en: 'Rules', ar: 'القوانين' },
                    { path: '/suggestions', icon: 'fa-lightbulb', en: 'Suggestions', ar: 'الاقتراحات' },
                    { path: '/apply', icon: 'fa-user-plus', en: 'Applications', ar: 'التقديمات' },
                    { path: '/giveaway', icon: 'fa-gift', en: 'Giveaways', ar: 'السحوبات' },
                    { path: '/tempChannels', icon: 'fa-microphone', en: 'Temp Channels', ar: 'الرومات المؤقتة' },
                    { path: '/autoreply', icon: 'fa-reply', en: 'Auto Reply', ar: 'الرد التلقائي' }
                ] %>
                <% configLinks.forEach(link => { %>
                    <a href="<%= link.path %>" class="nav-item <%= path === link.path ? 'active' : '' %>">
                        <i class="fas <%= link.icon %> w-5 text-center text-[15px]"></i>
                        <span class="font-medium text-sm"><%= currentLang === 'ar' ? link.ar : link.en %></span>
                    </a>
                <% }) %>
            </div>
        </div>

        <!-- PROTECTION -->
        <div class="mb-5">
            <h2 class="px-3 text-[10px] font-bold text-gray-500 uppercase tracking-[0.15em] mb-2">
                <%= currentLang === 'ar' ? 'الحماية' : 'Protection' %>
            </h2>
            <div class="space-y-0.5">
                <a href="/protection" class="nav-item <%= path === '/protection' ? 'active' : '' %>">
                    <i class="fas fa-shield-halved w-5 text-center text-[15px]"></i>
                    <span class="font-medium text-sm"><%= currentLang === 'ar' ? 'إعدادات الحماية' : 'Protection Settings' %></span>
                </a>
            </div>
        </div>

        <!-- COMING SOON -->
        <div class="mb-3">
            <h2 class="px-3 text-[10px] font-bold text-gray-500 uppercase tracking-[0.15em] mb-2">
                <%= currentLang === 'ar' ? 'قريبا' : 'Coming Soon' %>
            </h2>
            <div class="space-y-0.5">
                <% const comingSoonLinks = [
                    { path: '/welcome', icon: 'fa-hand', en: 'Welcome', ar: 'الترحيب' },
                    { path: '/selectroles', icon: 'fa-id-badge', en: 'Select Roles', ar: 'الرتب' },
                    { path: '/games', icon: 'fa-gamepad', en: 'Games', ar: 'الألعاب' },
                    { path: '/automod', icon: 'fa-robot', en: 'AutoMod', ar: 'الإشراف التلقائي' }
                ] %>
                <% comingSoonLinks.forEach(link => { %>
                    <a href="<%= link.path %>" class="nav-item nav-item-soon <%= path === link.path ? 'active' : '' %>">
                        <i class="fas <%= link.icon %> w-5 text-center text-[15px]"></i>
                        <span class="font-medium text-sm flex-1"><%= currentLang === 'ar' ? link.ar : link.en %></span>
                        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-amber-500/15 text-amber-400">SOON</span>
                    </a>
                <% }) %>
            </div>
        </div>
    </nav>

    <!-- Selected Server -->
    <% if (locals.selectedGuildName) { %>
    <div class="mx-3 mb-2 p-3 rounded-xl bg-white/[0.03] border border-white/[0.05] flex items-center gap-2.5">
      <% if (locals.selectedGuildIcon) { %>
        <img src="<%= locals.selectedGuildIcon %>" class="w-8 h-8 rounded-lg object-cover ring-1 ring-white/10 flex-shrink-0" alt="">
      <% } else { %>
        <div class="w-8 h-8 rounded-lg bg-indigo-500/20 flex items-center justify-center flex-shrink-0">
          <span class="text-indigo-300 font-bold text-sm"><%= locals.selectedGuildName.charAt(0) %></span>
        </div>
      <% } %>
      <div class="flex-1 min-w-0">
        <p class="text-xs font-bold text-white truncate"><%= locals.selectedGuildName %></p>
        <p class="text-[10px] text-gray-500">Active server</p>
      </div>
      <a href="/select-server" class="text-gray-500 hover:text-indigo-400 transition-colors text-[11px]" title="Switch server">
        <i class="fas fa-arrows-rotate"></i>
      </a>
    </div>
    <% } %>

    <div class="px-3 py-3 border-t border-white/5 space-y-2">
        <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-white/[0.03]">
            <div class="flex items-center gap-2">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                <span class="text-xs font-semibold text-gray-300">
                    <%= locale.dashboard.status.online %>
                </span>
            </div>
            <select id="languageSelect" onchange="window.location.href='?lang='+this.value" class="text-xs bg-transparent text-gray-400 font-medium focus:outline-none cursor-pointer">
                <option value="en" class="bg-[#15171C]" <%= currentLang === 'en' ? 'selected' : '' %>>EN</option>
                <option value="ar" class="bg-[#15171C]" <%= currentLang === 'ar' ? 'selected' : '' %>>AR</option>
            </select>
        </div>

        <div class="flex items-center justify-center gap-2">
            <a href="https://github.com/moazsam08-eng" target="_blank" class="flex-1 flex items-center justify-center gap-2 py-2 rounded-lg bg-white/[0.03] hover:bg-white/[0.08] text-gray-400 hover:text-white text-xs font-semibold transition-all">
                <i class="fab fa-github text-sm"></i>
                <span>GitHub</span>
            </a>
            <a href="https://discord.com/users/1485276849717379135" target="_blank" class="flex-1 flex items-center justify-center gap-2 py-2 rounded-lg bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 hover:text-indigo-300 text-xs font-semibold transition-all">
                <i class="fab fa-discord text-sm"></i>
                <span>Discord</span>
            </a>
        </div>
    </div>
</div>

<style>
.nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    color: #9CA3AF;
    transition: all 0.18s ease;
    position: relative;
}
.nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #E5E7EB;
}
.nav-item.active {
    background: linear-gradient(90deg, rgba(88, 101, 242, 0.18), rgba(88, 101, 242, 0.04));
    color: #FFFFFF;
}
.nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    background: #5865F2;
    border-radius: 0 3px 3px 0;
}
.nav-item.active i {
    color: #5865F2;
}
.nav-item-soon {
    opacity: 0.7;
}

.custom-scrollbar::-webkit-scrollbar {
    width: 4px;
}
.custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
}
.custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.12);
}

[dir="rtl"] .sidebar {
    left: auto;
    right: 0;
    border-right: none;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
}
[dir="rtl"] .nav-item.active::before {
    left: auto;
    right: 0;
    border-radius: 3px 0 0 3px;
}
</style>
