<!DOCTYPE html>
<html lang="<%= currentLanguage %>" dir="<%= currentLanguage === 'ar' ? 'rtl' : 'ltr' %>" class="dark bg-[#0B0C10]">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Moaz Studio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- contentFor('styles') %>
</head>
<body class="bg-[#0B0C10] text-gray-100 min-h-screen">
  <%- include('sidebar', { path: locals.path, currentLang: locals.currentLang, locale: locals.locale }) %>

  <div class="lg:pl-[280px] min-h-screen flex flex-col">
    <!-- Top bar -->
    <header class="sticky top-0 z-30 flex items-center justify-between px-6 py-3.5 bg-[#0B0C10]/90 backdrop-blur border-b border-white/[0.05]">
      <div class="flex items-center gap-3">
        <button id="mobileNavToggle" class="lg:hidden w-9 h-9 rounded-lg bg-white/[0.04] hover:bg-white/[0.08] flex items-center justify-center text-gray-400">
          <i class="fas fa-bars text-sm"></i>
        </button>
        <div>
          <h2 class="text-sm font-bold text-white"><%= title %></h2>
          <p class="text-[11px] text-gray-500"><%= locals.breadcrumbs || 'Dashboard' %></p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <select id="languageSelect" onchange="window.location.href='?lang='+this.value"
                class="text-xs bg-white/[0.04] border border-white/[0.06] text-gray-300 rounded-lg px-3 py-1.5 focus:outline-none cursor-pointer hover:bg-white/[0.08] transition-colors">
          <option value="en" class="bg-[#15171C]" <%= currentLanguage === 'en' ? 'selected' : '' %>>🇺🇸 EN</option>
          <option value="ar" class="bg-[#15171C]" <%= currentLanguage === 'ar' ? 'selected' : '' %>>🇸🇦 AR</option>
        </select>
        <a href="/logout"
           class="flex items-center gap-2 text-xs font-semibold text-gray-400 hover:text-red-400 px-3 py-1.5 rounded-lg bg-white/[0.03] hover:bg-red-500/10 border border-white/[0.05] hover:border-red-500/20 transition-all">
          <i class="fas fa-right-from-bracket"></i>
          <span class="hidden sm:inline">Logout</span>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 px-5 py-6 md:px-8">
      <%- contentFor('body') %>
    </main>

    <!-- Footer -->
    <footer class="px-8 py-4 border-t border-white/[0.04] flex items-center justify-between">
      <span class="text-xs text-gray-600">Powered by <span class="text-indigo-400 font-semibold">Moaz Studio</span></span>
      <span class="text-xs text-gray-600">v1.0.0</span>
    </footer>
  </div>

  <div id="mobileNavOverlay" class="mobile-nav-overlay"></div>
  <div id="toastContainer" class="fixed bottom-4 right-4 z-50 space-y-2"></div>

  <script src="/js/main.js"></script>
  <script src="/js/theme.js"></script>
  <script src="/js/utils.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/api.js"></script>
  <%- contentFor('scripts') %>
</body>
</html>
